<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COCOCAFE JOGOS — Sistema de Ventas" Height="768" Width="1024" 
        WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="#EFEBE4">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═════════════════════════════════════════ -->
        <!-- SIDEBAR                                    -->
        <!-- ═════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#1A1514">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="0,30,0,35">
                    <TextBlock Text="☕" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="COCOCAFE" FontSize="22" FontWeight="Bold" Foreground="#EFEBE4" 
                               HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock Text="JOGOS" FontSize="12" FontWeight="SemiBold" Foreground="#8C5A35" 
                               HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                    <Border Height="1" Background="#3D2B1F" Margin="30,20,30,0"/>
                </StackPanel>

                <!-- Menú -->
                <StackPanel Grid.Row="1" Margin="8,0">
                    <Button x:Name="btnDashboard" Style="{StaticResource SidebarButtonActive}" 
                            Click="btnDashboard_Click">
                        <Grid Width="220">
                            <TextBlock Text="🏠  Dashboard" VerticalAlignment="Center"/>
                            <Border x:Name="badgeAlerta" Background="#C0392B" CornerRadius="10"
                                    Width="22" Height="22" HorizontalAlignment="Right" 
                                    VerticalAlignment="Center" Margin="0,0,5,0" Visibility="Collapsed">
                                <TextBlock x:Name="lblBadgeCount" Text="0" Foreground="White"
                                           FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button x:Name="btnPOS" Style="{StaticResource SidebarButton}" 
                            Content="🎲  Punto de Venta" Click="btnPOS_Click"/>

                    <Button x:Name="btnInventario" Style="{StaticResource SidebarButton}" 
                            Content="📦  Inventario" Click="btnInventario_Click"/>

                    <Button x:Name="btnReportes" Style="{StaticResource SidebarButton}" 
                            Content="📊  Reportes" Click="btnReportes_Click"/>

                    <Button x:Name="btnUsuarios" Style="{StaticResource SidebarButton}" 
                            Content="👥  Gestión de Usuarios" Click="btnUsuarios_Click"
                            Visibility="Collapsed"/>
                </StackPanel>

                <!-- Footer: Usuario + Logout -->
                <StackPanel Grid.Row="2" Margin="20,0,20,20">
                    <Border Height="1" Background="#3D2B1F" Margin="0,0,0,15"/>
                    
                    <!-- Info del usuario logueado -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock x:Name="lblNombreUsuario" Text="Usuario" FontSize="13" 
                                   FontWeight="SemiBold" Foreground="#EFEBE4" 
                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Border Background="#3D2B1F" CornerRadius="10" Padding="10,3" 
                                HorizontalAlignment="Center" Margin="0,5,0,0">
                            <TextBlock x:Name="lblRolUsuario" Text="Rol" FontSize="10" 
                                       FontWeight="Bold" Foreground="#8C5A35" 
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- Fecha -->
                    <TextBlock x:Name="lblFecha" Text="" FontSize="11" Foreground="#8C5A35" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    
                    <!-- Botón Cerrar Sesión -->
                    <Button x:Name="btnLogout" Content="🚪  Cerrar Sesión" Height="40" 
                            Cursor="Hand" Click="BtnLogout_Click"
                            Background="#3D2B1F" Foreground="#D9CBB8" FontSize="13" 
                            FontWeight="SemiBold" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="10,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#C0392B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <TextBlock Text="v1.1" FontSize="10" Foreground="#4A3525" 
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═════════════════════════════════════════ -->
        <!-- ÁREA PRINCIPAL                             -->
        <!-- ═════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="#EFEBE4" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="65"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#F8F5F0" BorderBrush="#E8E0D5" BorderThickness="0,0,0,1">
                    <Grid Margin="25,0">
                        <TextBlock x:Name="lblTituloSeccion" Text="Dashboard" FontSize="22" 
                                   FontWeight="Bold" Foreground="#1A1514" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblHora" Text="" FontSize="13" Foreground="#8C5A35"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Contenido -->
                <ContentControl x:Name="AreaPrincipal" Grid.Row="1" Margin="20,15,20,20"/>
            </Grid>
        </Border>
    </Grid>
</Window>