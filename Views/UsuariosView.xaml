<UserControl x:Class="WpfApp1.Views.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Background="Transparent" d:DesignHeight="700" d:DesignWidth="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- PANEL IZQUIERDO: FORMULARIO              -->
        <!-- ═══════════════════════════════════════ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
            <StackPanel>

                <!-- Formulario Nuevo Usuario -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Registrar Nuevo Usuario" FontSize="15" FontWeight="SemiBold" 
                                   Foreground="#2C2C2C" Margin="0,0,0,16"
                                   FontFamily="Segoe UI, Arial"/>

                        <TextBlock Text="NOMBRE COMPLETO" FontSize="10" Foreground="#7A7A7A" FontWeight="SemiBold" 
                                   Margin="0,0,0,4" FontFamily="Segoe UI, Arial"/>
                        <TextBox x:Name="txtNombreUsuario" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="NOMBRE DE USUARIO" FontSize="10" Foreground="#7A7A7A" FontWeight="SemiBold" 
                                   Margin="0,0,0,4" FontFamily="Segoe UI, Arial"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="CONTRASENA" FontSize="10" Foreground="#7A7A7A" FontWeight="SemiBold" 
                                   Margin="0,0,0,4" FontFamily="Segoe UI, Arial"/>
                        <TextBox x:Name="txtPassword" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="ROL" FontSize="10" Foreground="#7A7A7A" FontWeight="SemiBold" 
                                   Margin="0,0,0,4" FontFamily="Segoe UI, Arial"/>
                        <ComboBox x:Name="cmbRol" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16">
                            <ComboBoxItem Content="Vendedor" IsSelected="True"/>
                        </ComboBox>

                        <!-- Info -->
                        <Border Background="#F5F3F0" CornerRadius="6" Padding="12,10" Margin="0,0,0,16"
                                BorderBrush="#E0DBD4" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Solo se pueden crear usuarios con rol Vendedor." 
                                           FontSize="11" Foreground="#7A7A7A" TextWrapping="Wrap"
                                           FontFamily="Segoe UI, Arial"/>
                            </StackPanel>
                        </Border>

                        <Button Content="GUARDAR USUARIO" Style="{StaticResource PrimaryButton}" 
                                Height="40" Click="BtnGuardarUsuario_Click"/>

                        <TextBlock x:Name="lblMensaje" Foreground="#27AE60" FontWeight="Medium" 
                                   Margin="0,10,0,0" TextAlignment="Center" TextWrapping="Wrap" FontSize="11"
                                   FontFamily="Segoe UI, Arial"/>
                    </StackPanel>
                </Border>

                <!-- Acciones sobre usuario seleccionado -->
                <Border x:Name="panelAccionesUsuario" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Acciones del Usuario" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#2C2C2C" Margin="0,0,0,8" FontFamily="Segoe UI, Arial"/>
                        <TextBlock x:Name="lblUsuarioSeleccionado" Text="" FontSize="12" 
                                   Foreground="#7A7A7A" Margin="0,0,0,4" TextWrapping="Wrap"
                                   FontFamily="Segoe UI, Arial"/>
                        <TextBlock x:Name="lblRolSeleccionado" Text="" FontSize="11" 
                                   Foreground="#2C2C2C" Margin="0,0,0,12"
                                   FontFamily="Segoe UI, Arial"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnToggleActivo" Grid.Column="0" Content="Desactivar" 
                                    Style="{StaticResource DangerButton}" Height="36"
                                    Click="BtnToggleActivo_Click"/>

                            <Button Grid.Column="2" Content="Reset Pass" 
                                    Style="{StaticResource PrimaryButton}" Height="36"
                                    Click="BtnResetPassword_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════ -->
        <!-- PANEL DERECHO: TABLA DE USUARIOS         -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Lista de Usuarios" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C2C2C" VerticalAlignment="Center"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock x:Name="lblConteoUsuarios" Text="0 usuarios" FontSize="11" 
                               Foreground="#A0A0A0" HorizontalAlignment="Right" VerticalAlignment="Center"
                               FontFamily="Segoe UI, Arial"/>
                </Grid>

                <DataGrid x:Name="GridUsuarios" Grid.Row="1" 
                          Style="{StaticResource ModernDataGrid}"
                          ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}"
                          CellStyle="{StaticResource ModernDataGridCell}"
                          SelectionChanged="GridUsuarios_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding IdUsuario}" Width="50"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                        <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="120"/>
                        <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="100"/>
                        <DataGridTemplateColumn Header="Estado" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="8,3" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Activo}" Value="0">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Activo"/>
                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="10"/>
                                                    <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Activo}" Value="0">
                                                            <Setter Property="Text" Value="Inactivo"/>
                                                            <Setter Property="Foreground" Value="#C0392B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
