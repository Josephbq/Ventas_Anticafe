<UserControl x:Class="WpfApp1.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="Transparent" d:DesignHeight="800" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <!-- ═══════════════════════════════════════ -->
            <!-- FILA 1: CARDS DE RESUMEN                -->
            <!-- ═══════════════════════════════════════ -->
            <UniformGrid Columns="4" Margin="0,0,0,20">

                <!-- Ventas del Día -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="28" Margin="0,0,0,8"/>
                        <TextBlock Text="Ventas del Día" FontSize="12" Foreground="#8C5A35" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblVentasDia" Text="0.00 Bs" FontSize="26" FontWeight="Bold" Foreground="#1A1514" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Ganancia del Día -->
                <Border Style="{StaticResource Card}" Margin="5,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📈" FontSize="28" Margin="0,0,0,8"/>
                        <TextBlock Text="Ganancia del Día" FontSize="12" Foreground="#27AE60" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblGananciaDia" Text="0.00 Bs" FontSize="26" FontWeight="Bold" Foreground="#27AE60" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Stock Bajo -->
                <Border Style="{StaticResource Card}" Margin="5,0,10,0">
                    <StackPanel>
                        <TextBlock Text="⚠️" FontSize="28" Margin="0,0,0,8"/>
                        <TextBlock Text="Alertas de Stock" FontSize="12" Foreground="#F39C12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblAlertasStock" Text="0" FontSize="26" FontWeight="Bold" Foreground="#F39C12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Mesas Activas -->
                <Border Style="{StaticResource Card}" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🪑" FontSize="28" Margin="0,0,0,8"/>
                        <TextBlock Text="Mesas Activas" FontSize="12" Foreground="#8C5A35" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock x:Name="lblMesasActivas" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1A1514"/>
                            <TextBlock x:Name="lblMesasTotal" Text=" / 0" FontSize="16" Foreground="#8C5A35" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══════════════════════════════════════ -->
            <!-- FILA 2: GRÁFICOS TOP PRODUCTOS + HORAS  -->
            <!-- ═══════════════════════════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Top 5 Productos -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🏆 Productos Más Vendidos (30 días)" FontSize="14" FontWeight="Bold" 
                                   Foreground="#1A1514" Margin="0,0,0,10"/>
                        <lvc:CartesianChart x:Name="chartTopProductos" Height="250"
                                            TooltipPosition="Center"/>
                    </StackPanel>
                </Border>

                <!-- Ventas por Hora -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🕐 Ventas por Hora (Hoy)" FontSize="14" FontWeight="Bold" 
                                   Foreground="#1A1514" Margin="0,0,0,10"/>
                        <lvc:CartesianChart x:Name="chartVentasHora" Height="250"
                                            TooltipPosition="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════ -->
            <!-- FILA 3: PIE CHART + ALERTAS              -->
            <!-- ═══════════════════════════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Distribución Juegos vs Cafetería -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🎲 vs ☕ Distribución Ventas" FontSize="14" FontWeight="Bold" 
                                   Foreground="#1A1514" Margin="0,0,0,10"/>
                        <lvc:PieChart x:Name="chartCategoria" Height="230"
                                      TooltipPosition="Center"/>
                        <StackPanel x:Name="panelLeyenda" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Panel de Alertas -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🔔 Alertas de Inventario" FontSize="14" FontWeight="Bold" 
                                   Foreground="#1A1514" Margin="0,0,0,10"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="260">
                            <StackPanel x:Name="panelAlertas">
                                <TextBlock x:Name="lblSinAlertas" Text="✅ Todo en orden, no hay alertas" 
                                           Foreground="#27AE60" FontSize="14" Margin="0,20,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════ -->
            <!-- FILA 4: VENTAS POR DÍA DE SEMANA         -->
            <!-- ═══════════════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="📅 Ventas por Día de Semana (Últimas 4 semanas)" FontSize="14" FontWeight="Bold" 
                               Foreground="#1A1514" Margin="0,0,0,10"/>
                    <lvc:CartesianChart x:Name="chartVentasDia" Height="220"
                                        TooltipPosition="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
