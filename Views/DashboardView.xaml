<UserControl x:Class="WpfApp1.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="Transparent" d:DesignHeight="800" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="5">

            <!-- ═══════════════════════════════════════ -->
            <!-- FILA 1: CARDS DE RESUMEN                -->
            <!-- ═══════════════════════════════════════ -->
            <UniformGrid Columns="4" Margin="0,0,0,18">

                <!-- Ventas del Dia -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <Border Background="#F5F0E8" CornerRadius="8" Width="40" Height="40" 
                                HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="$" FontSize="18" Foreground="#6B4F3A" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI, Arial"/>
                        </Border>
                        <TextBlock Text="Ventas del Dia" FontSize="11" Foreground="#7A7A7A" FontWeight="Medium"
                                   FontFamily="Segoe UI, Arial"/>
                        <TextBlock x:Name="lblVentasDia" Text="0.00 Bs" FontSize="22" FontWeight="Bold" 
                                   Foreground="#2C2C2C" Margin="0,3,0,0" FontFamily="Segoe UI, Arial"/>
                    </StackPanel>
                </Border>

                <!-- Ganancia del Dia -->
                <Border Style="{StaticResource Card}" Margin="4,0,8,0">
                    <StackPanel>
                        <Border Background="#E8F5E9" CornerRadius="8" Width="40" Height="40" 
                                HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="&#x2191;" FontSize="20" Foreground="#27AE60" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI, Arial"/>
                        </Border>
                        <TextBlock Text="Ganancia del Dia" FontSize="11" Foreground="#27AE60" FontWeight="Medium"
                                   FontFamily="Segoe UI, Arial"/>
                        <TextBlock x:Name="lblGananciaDia" Text="0.00 Bs" FontSize="22" FontWeight="Bold" 
                                   Foreground="#27AE60" Margin="0,3,0,0" FontFamily="Segoe UI, Arial"/>
                    </StackPanel>
                </Border>

                <!-- Stock Bajo -->
                <Border Style="{StaticResource Card}" Margin="4,0,8,0">
                    <StackPanel>
                        <Border Background="#FFF3E0" CornerRadius="8" Width="40" Height="40" 
                                HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="!" FontSize="20" Foreground="#E67E22" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI, Arial"/>
                        </Border>
                        <TextBlock Text="Alertas de Stock" FontSize="11" Foreground="#E67E22" FontWeight="Medium"
                                   FontFamily="Segoe UI, Arial"/>
                        <TextBlock x:Name="lblAlertasStock" Text="0" FontSize="22" FontWeight="Bold" 
                                   Foreground="#E67E22" Margin="0,3,0,0" FontFamily="Segoe UI, Arial"/>
                    </StackPanel>
                </Border>

                <!-- Mesas Activas -->
                <Border Style="{StaticResource Card}" Margin="4,0,0,0">
                    <StackPanel>
                        <Border Background="#E8EAF6" CornerRadius="8" Width="40" Height="40" 
                                HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="M" FontSize="17" Foreground="#5C6BC0" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI, Arial"/>
                        </Border>
                        <TextBlock Text="Mesas Activas" FontSize="11" Foreground="#7A7A7A" FontWeight="Medium"
                                   FontFamily="Segoe UI, Arial"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock x:Name="lblMesasActivas" Text="0" FontSize="22" FontWeight="Bold" 
                                       Foreground="#2C2C2C" FontFamily="Segoe UI, Arial"/>
                            <TextBlock x:Name="lblMesasTotal" Text=" / 0" FontSize="14" Foreground="#A0A0A0" 
                                       VerticalAlignment="Bottom" Margin="0,0,0,2" FontFamily="Segoe UI, Arial"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══════════════════════════════════════ -->
            <!-- FILA 2: GRAFICOS TOP PRODUCTOS + HORAS  -->
            <!-- ═══════════════════════════════════════ -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Top 5 Productos -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,9,0">
                    <StackPanel>
                        <TextBlock Text="Productos Mas Vendidos (30 dias)" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#2C2C2C" Margin="0,0,0,10" FontFamily="Segoe UI, Arial"/>
                        <lvc:CartesianChart x:Name="chartTopProductos" Height="240"
                                            TooltipPosition="Center"/>
                    </StackPanel>
                </Border>

                <!-- Ventas por Hora -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="9,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Ventas por Hora (Hoy)" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#2C2C2C" Margin="0,0,0,10" FontFamily="Segoe UI, Arial"/>
                        <lvc:CartesianChart x:Name="chartVentasHora" Height="240"
                                            TooltipPosition="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════ -->
            <!-- FILA 3: PIE CHART + ALERTAS              -->
            <!-- ═══════════════════════════════════════ -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Distribucion Juegos vs Cafeteria -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,9,0">
                    <StackPanel>
                        <TextBlock Text="Distribucion de Ventas" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#2C2C2C" Margin="0,0,0,10" FontFamily="Segoe UI, Arial"/>
                        <lvc:PieChart x:Name="chartCategoria" Height="220"
                                      TooltipPosition="Center"/>
                        <StackPanel x:Name="panelLeyenda" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Panel de Alertas -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="9,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Alertas de Inventario" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#2C2C2C" Margin="0,0,0,10" FontFamily="Segoe UI, Arial"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="250">
                            <StackPanel x:Name="panelAlertas">
                                <TextBlock x:Name="lblSinAlertas" Text="Todo en orden, no hay alertas" 
                                           Foreground="#27AE60" FontSize="13" Margin="0,16,0,0"
                                           HorizontalAlignment="Center" FontFamily="Segoe UI, Arial"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════ -->
            <!-- FILA 4: VENTAS POR DIA DE SEMANA         -->
            <!-- ═══════════════════════════════════════ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Ventas por Dia de Semana (Ultimas 4 semanas)" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#2C2C2C" Margin="0,0,0,10" FontFamily="Segoe UI, Arial"/>
                    <lvc:CartesianChart x:Name="chartVentasDia" Height="200"
                                        TooltipPosition="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
