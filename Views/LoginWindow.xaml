<Window x:Class="WpfApp1.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COCOCAFE JOGOS - Login" Height="480" Width="400" 
        WindowStartupLocation="CenterScreen" Background="#F5F3F0" 
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Border Background="#F5F3F0" CornerRadius="12" MouseLeftButtonDown="Border_MouseLeftButtonDown"
            BorderBrush="#E0DBD4" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Close button -->
            <Button Grid.Row="0" Content="&#x2715;" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="0,12,14,0" Background="Transparent" Foreground="#A0A0A0" 
                    BorderThickness="0" FontSize="14" Cursor="Hand" Click="BtnCerrar_Click"
                    Width="28" Height="28" FontFamily="Segoe UI, Arial">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" 
                                Width="28" Height="28">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEEAE4"/>
                                <Setter Property="Foreground" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Central panel -->
            <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="10" Padding="36,24" Margin="24,0,24,24"
                    BorderBrush="#E0DBD4" BorderThickness="1">
                <StackPanel>
                    <!-- Logo -->
                    <TextBlock Text="COCOCAFE" FontSize="26" FontWeight="Bold" Foreground="#2C2C2C" 
                               HorizontalAlignment="Center" Margin="0,0,0,2" 
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock Text="JOGOS" FontSize="12" FontWeight="SemiBold" Foreground="#C9A96E" 
                               HorizontalAlignment="Center" Margin="0,0,0,24"
                               FontFamily="Segoe UI, Arial"/>

                    <!-- Separator -->
                    <Border Height="1" CornerRadius="1" Margin="16,0,16,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#E0DBD4" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Username -->
                    <TextBlock Text="USUARIO" Foreground="#7A7A7A" FontSize="10" FontWeight="SemiBold" 
                               Margin="4,0,0,5" FontFamily="Segoe UI, Arial"/>
                    <Border Background="#FAFAF8" CornerRadius="6" Padding="10,0" Margin="0,0,0,14"
                            BorderBrush="#E0DBD4" BorderThickness="1">
                        <TextBox x:Name="txtUser" Height="36" FontSize="13" 
                                 Background="Transparent" Foreground="#2C2C2C" 
                                 BorderThickness="0" VerticalContentAlignment="Center"
                                 CaretBrush="#6B4F3A" FontFamily="Segoe UI, Arial"/>
                    </Border>

                    <!-- Password -->
                    <TextBlock Text="CONTRASENA" Foreground="#7A7A7A" FontSize="10" FontWeight="SemiBold" 
                               Margin="4,0,0,5" FontFamily="Segoe UI, Arial"/>
                    <Border Background="#FAFAF8" CornerRadius="6" Padding="10,0" Margin="0,0,0,24"
                            BorderBrush="#E0DBD4" BorderThickness="1">
                        <PasswordBox x:Name="txtPass" Height="36" FontSize="13" 
                                     Background="Transparent" Foreground="#2C2C2C" 
                                     BorderThickness="0" VerticalContentAlignment="Center"
                                     CaretBrush="#6B4F3A" FontFamily="Segoe UI, Arial"/>
                    </Border>

                    <!-- Login Button -->
                    <Button x:Name="btnIngresar" Content="INGRESAR" Height="42" 
                            FontSize="14" Click="Login_Click" Cursor="Hand"
                            FontFamily="Segoe UI, Arial" FontWeight="SemiBold"
                            Foreground="#FFFFFF" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#6B4F3A" CornerRadius="6" 
                                        Padding="20,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#8B6F52"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Error -->
                    <TextBlock x:Name="lblError" Foreground="#C0392B" Margin="0,12,0,0" 
                               TextAlignment="Center" FontWeight="Medium" FontSize="11"
                               TextWrapping="Wrap" FontFamily="Segoe UI, Arial"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>