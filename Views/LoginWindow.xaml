<Window x:Class="WpfApp1.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="400" Width="350" WindowStartupLocation="CenterScreen" Background="#1E1E2F" WindowStyle="None" AllowsTransparency="True">
    <Grid>
        <Border Background="#2C2C3E" CornerRadius="15" Padding="20" Margin="20">
            <StackPanel>
                <TextBlock Text="Iniciar Sesión" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Usuario" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUser" Height="30" Margin="0,0,0,15" Background="#3A3A4F" Foreground="White" BorderThickness="0" Padding="5,5,5,5"/>

                <TextBlock Text="Contraseña" Foreground="White" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPass" Height="30" Margin="0,0,0,20" Background="#3A3A4F" Foreground="White" BorderThickness="0" Padding="5,5,5,5"/>

                <Button Content="Ingresar" Height="35" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="Login_Click"/>

                <TextBlock x:Name="lblError" Foreground="#FF5252" Margin="0,15,0,0" TextAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>