<Window x:Class="WpfApp1.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COCOCAFE JOGOS - Login" Height="530" Width="400" 
        WindowStartupLocation="CenterScreen" Background="#1A1514" 
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Border Background="#1A1514" CornerRadius="16" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Botón cerrar -->
            <Button Grid.Row="0" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="0,10,15,0" Background="Transparent" Foreground="#8C5A35" 
                    BorderThickness="0" FontSize="16" Cursor="Hand" Click="BtnCerrar_Click"
                    Width="30" Height="30"/>

            <!-- Panel central -->
            <Border Grid.Row="1" Background="#2D201A" CornerRadius="16" Padding="35,25" Margin="25,0,25,25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.3" Color="#000"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Logo -->
                    <TextBlock Text="☕" FontSize="38" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                    <TextBlock Text="COCOCAFE" FontSize="26" FontWeight="Bold" Foreground="#EFEBE4" 
                               HorizontalAlignment="Center" Margin="0,0,0,0" 
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="JOGOS" FontSize="13" FontWeight="SemiBold" Foreground="#8C5A35" 
                               HorizontalAlignment="Center" Margin="0,2,0,22"
                               FontFamily="Segoe UI"/>

                    <!-- Separador decorativo -->
                    <Border Height="2" Background="#3D2B1F" CornerRadius="1" Margin="30,0,30,20"/>

                    <!-- Campo Usuario -->
                    <TextBlock Text="USUARIO" Foreground="#8C5A35" FontSize="11" FontWeight="SemiBold" 
                               Margin="5,0,0,5"/>
                    <Border Background="#1A1514" CornerRadius="8" Padding="12,0" Margin="0,0,0,14">
                        <TextBox x:Name="txtUser" Height="38" FontSize="14" 
                                 Background="Transparent" Foreground="#EFEBE4" 
                                 BorderThickness="0" VerticalContentAlignment="Center"
                                 CaretBrush="#8C5A35"/>
                    </Border>

                    <!-- Campo Contraseña -->
                    <TextBlock Text="CONTRASEÑA" Foreground="#8C5A35" FontSize="11" FontWeight="SemiBold" 
                               Margin="5,0,0,5"/>
                    <Border Background="#1A1514" CornerRadius="8" Padding="12,0" Margin="0,0,0,20">
                        <PasswordBox x:Name="txtPass" Height="38" FontSize="14" 
                                     Background="Transparent" Foreground="#EFEBE4" 
                                     BorderThickness="0" VerticalContentAlignment="Center"
                                     CaretBrush="#8C5A35"/>
                    </Border>

                    <!-- Botón Ingresar -->
                    <Button x:Name="btnIngresar" Content="INGRESAR" Height="45" Style="{StaticResource PrimaryButton}"
                            FontSize="15" Click="Login_Click"/>

                    <!-- Error -->
                    <TextBlock x:Name="lblError" Foreground="#C0392B" Margin="0,12,0,0" 
                               TextAlignment="Center" FontWeight="SemiBold" FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>