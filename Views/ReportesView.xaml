<UserControl x:Class="WpfApp1.Views.ReportesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Background="Transparent" d:DesignHeight="700" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- FILA 1: FILTROS                          -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Periodo -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="PERIODO" FontSize="10" Foreground="#7A7A7A" FontWeight="SemiBold" 
                               Margin="0,0,0,5" FontFamily="Segoe UI, Arial"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnDiario" Content="Diario" Style="{StaticResource ToggleBtnActive}" 
                                Click="BtnPeriodo_Click" Tag="DIARIO"/>
                        <Button x:Name="btnSemanal" Content="Semanal" Style="{StaticResource ToggleBtn}" 
                                Click="BtnPeriodo_Click" Tag="SEMANAL"/>
                        <Button x:Name="btnMensual" Content="Mensual" Style="{StaticResource ToggleBtn}" 
                                Click="BtnPeriodo_Click" Tag="MENSUAL"/>
                    </StackPanel>
                </StackPanel>

                <!-- Categoria -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="CATEGORIA" FontSize="10" Foreground="#7A7A7A" FontWeight="SemiBold" 
                               Margin="0,0,0,5" FontFamily="Segoe UI, Arial"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnCatTodos" Content="Todos" Style="{StaticResource ToggleBtnActive}" 
                                Click="BtnCategoria_Click" Tag="TODOS"/>
                        <Button x:Name="btnCatCafe" Content="Cafeteria" Style="{StaticResource ToggleBtn}" 
                                Click="BtnCategoria_Click" Tag="CAFETERIA"/>
                        <Button x:Name="btnCatJuegos" Content="Juegos" Style="{StaticResource ToggleBtn}" 
                                Click="BtnCategoria_Click" Tag="JUEGOS"/>
                    </StackPanel>
                </StackPanel>

                <!-- Fecha -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="FECHA" FontSize="10" Foreground="#7A7A7A" FontWeight="SemiBold" 
                               Margin="0,0,0,5" FontFamily="Segoe UI, Arial"/>
                    <DatePicker x:Name="dpFecha" Width="150" Height="30" 
                                SelectedDateChanged="DpFecha_SelectedDateChanged"/>
                </StackPanel>

                <!-- Rango mostrado -->
                <StackPanel Grid.Column="5" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                    <TextBlock x:Name="lblRangoFechas" Text="" FontSize="11" Foreground="#A0A0A0" 
                               FontWeight="Medium" TextAlignment="Right" FontFamily="Segoe UI, Arial"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- FILA 2: CARDS DE RESUMEN                 -->
        <!-- ═══════════════════════════════════════ -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Ventas Totales" FontSize="10" Foreground="#7A7A7A" FontWeight="Medium"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock x:Name="lblTotalVentas" Text="0.00 Bs" FontSize="20" FontWeight="Bold" 
                               Foreground="#2C2C2C" Margin="0,4,0,0" FontFamily="Segoe UI, Arial"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="4,0,8,0">
                <StackPanel>
                    <TextBlock Text="Costo Total" FontSize="10" Foreground="#C0392B" FontWeight="Medium"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock x:Name="lblTotalCosto" Text="0.00 Bs" FontSize="20" FontWeight="Bold" 
                               Foreground="#C0392B" Margin="0,4,0,0" FontFamily="Segoe UI, Arial"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="4,0,8,0">
                <StackPanel>
                    <TextBlock Text="Ganancia Bruta" FontSize="10" Foreground="#27AE60" FontWeight="Medium"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock x:Name="lblGanancia" Text="0.00 Bs" FontSize="20" FontWeight="Bold" 
                               Foreground="#27AE60" Margin="0,4,0,0" FontFamily="Segoe UI, Arial"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="Transacciones" FontSize="10" Foreground="#7A7A7A" FontWeight="Medium"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock x:Name="lblTransacciones" Text="0" FontSize="20" FontWeight="Bold" 
                               Foreground="#2C2C2C" Margin="0,4,0,0" FontFamily="Segoe UI, Arial"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ═══════════════════════════════════════ -->
        <!-- FILA 3: TABLA DETALLADA                  -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Desglose por Producto" FontSize="13" FontWeight="SemiBold" 
                           Foreground="#2C2C2C" Margin="0,0,0,10" FontFamily="Segoe UI, Arial"/>

                <DataGrid x:Name="GridReporte" Grid.Row="1"
                          Style="{StaticResource ModernDataGrid}"
                          ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}"
                          CellStyle="{StaticResource ModernDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="*"/>
                        <DataGridTextColumn Header="Categoria" Binding="{Binding Tipo}" Width="90"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadVendida}" Width="75"/>
                        <DataGridTextColumn Header="Precio Prom." Binding="{Binding PrecioPromedioVentaStr}" Width="100"/>
                        <DataGridTextColumn Header="Costo Prom." Binding="{Binding CostoPromedioStr}" Width="100"/>
                        <DataGridTextColumn Header="Total Ventas" Binding="{Binding TotalVentasStr}" Width="100"/>
                        <DataGridTextColumn Header="Ganancia" Binding="{Binding GananciaStr}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!-- FILA 4: ACCIONES                         -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,12,0,0">
            <Grid>
                <Button x:Name="btnExportarPDF" Content="Exportar Reporte PDF" 
                        Style="{StaticResource DarkButton}" HorizontalAlignment="Left"
                        Width="200" Height="38" Click="BtnExportarPDF_Click"/>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock Text="Total del periodo:  " FontSize="13" Foreground="#7A7A7A" 
                               VerticalAlignment="Center" FontWeight="Medium"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock x:Name="lblGranTotal" Text="0.00 Bs" FontSize="20" FontWeight="Bold" 
                               Foreground="#6B4F3A" VerticalAlignment="Center"
                               FontFamily="Segoe UI, Arial"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>