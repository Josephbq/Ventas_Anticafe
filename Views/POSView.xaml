<UserControl x:Class="WpfApp1.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             Background="Transparent" d:DesignHeight="700" d:DesignWidth="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- PANEL IZQUIERDO: MESAS + PRODUCTOS      -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Mesas -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Selecciona una Mesa" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C2C2C" Margin="0,0,0,10" FontFamily="Segoe UI, Arial"/>
                    <WrapPanel x:Name="PanelMesas" Orientation="Horizontal"/>
                </StackPanel>
            </Border>

            <!-- Productos con Tabs -->
            <Border Grid.Row="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Menu de Productos" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#2C2C2C" Margin="0,0,0,10" FontFamily="Segoe UI, Arial"/>

                    <!-- Tabs de categoria -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="btnTabTodos" Content="Todos" Style="{StaticResource ToggleBtnActive}" 
                                Click="BtnTab_Click" Tag="TODOS"/>
                        <Button x:Name="btnTabCafe" Content="Cafeteria" Style="{StaticResource ToggleBtn}" 
                                Click="BtnTab_Click" Tag="CAFETERIA"/>
                        <Button x:Name="btnTabJuegos" Content="Juegos" Style="{StaticResource ToggleBtn}" 
                                Click="BtnTab_Click" Tag="JUEGOS"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="PanelProductos" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════ -->
        <!-- PANEL DERECHO: TICKET / CUENTA           -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Mesa seleccionada -->
                <Border Grid.Row="0" Background="#6B4F3A" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                    <TextBlock x:Name="lblMesaSeleccionada" Text="Selecciona una mesa" FontSize="13" 
                               FontWeight="SemiBold" Foreground="#FFFFFF" FontFamily="Segoe UI, Arial"/>
                </Border>

                <!-- Encabezado ticket -->
                <Grid Grid.Row="1" Margin="4,4,4,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Qty" FontSize="10" Foreground="#A0A0A0" FontWeight="SemiBold"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock Grid.Column="1" Text="Producto" FontSize="10" Foreground="#A0A0A0" FontWeight="SemiBold"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock Grid.Column="2" Text="Precio" FontSize="10" Foreground="#A0A0A0" FontWeight="SemiBold"
                               FontFamily="Segoe UI, Arial"/>
                    <TextBlock Grid.Column="3" Text="Subtotal" FontSize="10" Foreground="#A0A0A0" FontWeight="SemiBold" 
                               TextAlignment="Right" FontFamily="Segoe UI, Arial"/>
                </Grid>

                <!-- Lista del ticket -->
                <Border Grid.Row="2" BorderBrush="#E0DBD4" BorderThickness="0,1,0,1">
                    <ListBox x:Name="ListaTicket" Background="Transparent" BorderThickness="0"
                             Foreground="#2C2C2C" FontSize="12" 
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             FontFamily="Segoe UI, Arial"/>
                </Border>

                <!-- Boton quitar -->
                <Button Grid.Row="3" Content="Quitar Seleccionado" Height="34"
                        Style="{StaticResource DangerButton}" Margin="0,8,0,0"
                        Click="BtnQuitarProducto_Click"/>

                <!-- Total + Cobrar -->
                <StackPanel Grid.Row="4" Margin="0,10,0,0">
                    <Border Background="#F5F3F0" CornerRadius="6" Padding="14,10" Margin="0,0,0,10"
                            BorderBrush="#E0DBD4" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="TOTAL" FontSize="12" Foreground="#7A7A7A" FontWeight="SemiBold" 
                                       VerticalAlignment="Center" FontFamily="Segoe UI, Arial"/>
                            <TextBlock x:Name="lblTotal" Text="0.00 Bs" FontSize="20" FontWeight="Bold" 
                                       Foreground="#6B4F3A" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontFamily="Segoe UI, Arial"/>
                        </Grid>
                    </Border>

                    <Button Content="COBRAR Y CERRAR MESA" Height="44"
                            Style="{StaticResource DarkButton}" FontSize="14"
                            Click="BtnCobrar_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>