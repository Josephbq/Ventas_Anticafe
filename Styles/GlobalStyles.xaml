<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════ -->
    <!-- PALETA — Neutral Light + Coffee/Beige Accents  -->
    <!-- ══════════════════════════════════════════════ -->

    <!-- Canvas / Fondos -->
    <SolidColorBrush x:Key="NegroFondo"      Color="#1B1B1B"/>
    <SolidColorBrush x:Key="NegroSuave"      Color="#242424"/>
    <SolidColorBrush x:Key="CafeOscuro"      Color="#6B4F3A"/>
    <SolidColorBrush x:Key="CafeMedio"       Color="#8B6F52"/>
    <SolidColorBrush x:Key="CafeClaro"       Color="#A68966"/>
    <SolidColorBrush x:Key="BeigeCalido"     Color="#C9A96E"/>
    <SolidColorBrush x:Key="BeigeClaro"      Color="#EDE8E0"/>
    <SolidColorBrush x:Key="Crema"           Color="#F5F3F0"/>
    <SolidColorBrush x:Key="BlancoCal"       Color="#FFFFFF"/>

    <!-- Acentos -->
    <SolidColorBrush x:Key="DoradoPrimario"  Color="#6B4F3A"/>
    <SolidColorBrush x:Key="DoradoClaro"     Color="#8B6F52"/>
    <SolidColorBrush x:Key="RojoAlerta"      Color="#C0392B"/>
    <SolidColorBrush x:Key="VerdeExito"      Color="#27AE60"/>
    <SolidColorBrush x:Key="AmbarWarn"       Color="#E67E22"/>

    <!-- Texto -->
    <SolidColorBrush x:Key="TextoPrimario"   Color="#2C2C2C"/>
    <SolidColorBrush x:Key="TextoSecundario" Color="#7A7A7A"/>
    <SolidColorBrush x:Key="TextoMuted"      Color="#A0A0A0"/>

    <!-- Bordes -->
    <SolidColorBrush x:Key="BordeSutil"      Color="#E0DBD4"/>
    <SolidColorBrush x:Key="BordeActivo"     Color="#6B4F3A"/>

    <!-- ══════════════════════════════════════════════ -->
    <!-- SIDEBAR BUTTONS                                -->
    <!-- ══════════════════════════════════════════════ -->
    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#9E9E9E"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="18,0,0,0"/>
        <Setter Property="Margin" Value="8,1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" CornerRadius="6">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#2E2E2E"/>
                            <Setter Property="Foreground" Value="#EEEEEE"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarButtonActive" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
        <Setter Property="Background" Value="#2E2E2E"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="#2E2E2E" Padding="{TemplateBinding Padding}" CornerRadius="6"
                            BorderBrush="#C9A96E" BorderThickness="3,0,0,0">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════ -->
    <!-- PRIMARY BUTTON — Coffee Brown                  -->
    <!-- ══════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="#6B4F3A"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#8B6F52"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#D5CFC7"/>
                            <Setter Property="Foreground" Value="#A0A0A0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Background" Value="#C0392B"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#E74C3C"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SuccessButton" TargetType="Button">
        <Setter Property="Background" Value="#27AE60"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#2ECC71"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkButton" TargetType="Button">
        <Setter Property="Background" Value="#6B4F3A"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#8B6F52"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════ -->
    <!-- TOGGLE / PILL BUTTONS                          -->
    <!-- ══════════════════════════════════════════════ -->
    <Style x:Key="ToggleBtn" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#7A7A7A"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,7"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="16" Padding="{TemplateBinding Padding}"
                            BorderBrush="#E0DBD4" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#EDE8E0"/>
                            <Setter Property="Foreground" Value="#2C2C2C"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToggleBtnActive" TargetType="Button">
        <Setter Property="Background" Value="#6B4F3A"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,7"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="#6B4F3A" CornerRadius="16"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════ -->
    <!-- TEXTBOX                                        -->
    <!-- ══════════════════════════════════════════════ -->
    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="Height" Value="38"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#2C2C2C"/>
        <Setter Property="CaretBrush" Value="#6B4F3A"/>
        <Setter Property="BorderBrush" Value="#E0DBD4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#6B4F3A"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default TextBox style -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="#2C2C2C"/>
        <Setter Property="CaretBrush" Value="#6B4F3A"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- Default PasswordBox style -->
    <Style TargetType="PasswordBox">
        <Setter Property="Foreground" Value="#2C2C2C"/>
        <Setter Property="CaretBrush" Value="#6B4F3A"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Background" Value="#FFFFFF"/>
    </Style>

    <!-- ══════════════════════════════════════════════ -->
    <!-- COMBOBOX                                       -->
    <!-- ══════════════════════════════════════════════ -->
    <Style x:Key="ModernComboBox" TargetType="ComboBox">
        <Setter Property="Height" Value="38"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#2C2C2C"/>
        <Setter Property="BorderBrush" Value="#E0DBD4"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ══════════════════════════════════════════════ -->
    <!-- DATAGRID                                       -->
    <!-- ══════════════════════════════════════════════ -->
    <Style x:Key="ModernDataGrid" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#E0DBD4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowHeight" Value="40"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#F0EDE8"/>
        <Setter Property="AlternatingRowBackground" Value="#FAFAF8"/>
        <Setter Property="RowBackground" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#2C2C2C"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="SelectionMode" Value="Single"/>
    </Style>

    <Style x:Key="ModernColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F5F3F0"/>
        <Setter Property="Foreground" Value="#6B4F3A"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderBrush" Value="#E0DBD4"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="ModernDataGridRow" TargetType="DataGridRow">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#EDE8E0"/>
                <Setter Property="Foreground" Value="#2C2C2C"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F5F0E8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#2C2C2C"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ══════════════════════════════════════════════ -->
    <!-- CARD                                           -->
    <!-- ══════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BorderBrush" Value="#E0DBD4"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="CardDark" TargetType="Border">
        <Setter Property="Background" Value="#F5F3F0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BorderBrush" Value="#E0DBD4"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="InventoryItemCard" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="BorderBrush" Value="#E0DBD4"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ══════════════════════════════════════════════ -->
    <!-- SCROLLBAR                                      -->
    <!-- ══════════════════════════════════════════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</ResourceDictionary>
